---
interface Props {
  companyId: string
}

const { companyId } = Astro.props
---

<script is:inline define:vars={{ companyId }}>
  (function () {
    function initialize() {
      if (window.LTWebchat && window.LTWebchat.initialize) {
        window.LTWebchat.initialize({ companyId: companyId });
      }
    }

    var existing = document.querySelector('script[data-leadtruffle-webchat]');
    if (existing) {
      initialize();
      return;
    }

    var s = document.createElement('script');
    s.src = 'https://embeds-v1.leadtruffle.com/webchat/webchat-widget.js';
    s.async = true;
    s.dataset.leadtruffleWebchat = 'true';
    s.onload = initialize;
    document.head.appendChild(s);
  })();
</script>

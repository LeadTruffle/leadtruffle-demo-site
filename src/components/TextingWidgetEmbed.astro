---
interface Props {
  companyId: string
}

const { companyId } = Astro.props
---

<script is:inline define:vars={{ companyId }}>
  (function () {
    function initialize() {
      if (window.LTWidget && window.LTWidget.initialize) {
        window.LTWidget.initialize({
          companyId: companyId,
        });
      }
    }

    var existing = document.querySelector('script[data-leadtruffle-texting]');
    if (existing) {
      initialize();
      return;
    }

    var s = document.createElement('script');
    s.src = 'https://embeds-v1.leadtruffle.com/tooldesk-widget.js';
    s.async = true;
    s.dataset.leadtruffleTexting = 'true';
    s.onload = initialize;
    document.head.appendChild(s);
  })();
</script>

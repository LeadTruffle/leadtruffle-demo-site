---
interface Props {
  companyId: string
  targetElement: string
}

const { companyId, targetElement } = Astro.props
---

<script is:inline define:vars={{ companyId, targetElement }}>
  (function () {
    function initialize() {
      if (window.TJSFormWidget && window.TJSFormWidget.initialize) {
        window.TJSFormWidget.initialize({
          companyId: companyId,
          targetElement: targetElement,
        });
      }
    }

    var existing = document.querySelector('script[data-leadtruffle-jsform]');
    if (existing) {
      initialize();
      return;
    }

    var s = document.createElement('script');
    s.src = 'https://embeds-v1.leadtruffle.com/jsform/jsform-widget.js';
    s.async = true;
    s.dataset.leadtruffleJsform = 'true';
    s.onload = initialize;
    document.head.appendChild(s);
  })();
</script>

---
import SiteLayout from '../layouts/SiteLayout.astro'
---

<SiteLayout title="Page not found | LeadTruffle Demo Lab" description="The page you requested does not exist.">
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">404</p>
      <h1>That page is not in the demo lab yet</h1>
      <p class="page-hero__copy">
        The route may have moved, or it may just not exist in this smaller demo-focused site.
      </p>
      <a class="text-link" href="/">Return home</a>
    </div>
  </section>
</SiteLayout>

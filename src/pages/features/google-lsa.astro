---
import SiteLayout from '../../layouts/SiteLayout.astro'

const pageTitle = 'Google LSA Autoresponder Demo | LeadTruffle Demo Lab'
const pageDescription =
  'A focused demo page for explaining how LeadTruffle can help teams respond to Google Local Services Ads leads.'
---

<SiteLayout title={pageTitle} description={pageDescription}>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Google LSA workflow</p>
      <h1>Answer Local Services Ads leads with more discipline</h1>
      <p class="page-hero__copy">
        This page should eventually demonstrate the difference between simply receiving an LSA lead
        and actually running a consistent, trackable, high-speed response process around it.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="shell detail-grid">
      <article class="detail-card">
        <h2>What the demo should prove</h2>
        <p>
          LeadTruffle can kick off a useful first touch quickly, capture key intent, and direct the
          lead into the right downstream workflow without the business babysitting every step.
        </p>
      </article>
      <article class="detail-card">
        <h2>Why this matters</h2>
        <p>
          Google LSA is often a high-value source, so the response pattern should feel measured and
          dependable, not frantic or template-heavy.
        </p>
      </article>
    </div>
  </section>
</SiteLayout>
